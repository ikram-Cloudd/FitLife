<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gg">

    <ImageView
        android:id="@+id/zebraMain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/zeee"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />




    <View
        android:id="@+id/herobar"
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:background="@color/navyy"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/vertbar"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:background="@color/navyy"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="90dp"
        android:layout_height="200dp"
        android:src="@drawable/homyw"
        app:layout_constraintBottom_toBottomOf="@+id/herobar"
        app:layout_constraintStart_toStartOf="@id/herobar"
        app:layout_constraintTop_toTopOf="@+id/herobar" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/accw"
        app:layout_constraintBottom_toTopOf="@+id/accTxt"
        app:layout_constraintStart_toStartOf="@id/accTxt"
        app:layout_constraintEnd_toEndOf="@id/accTxt"
        />
    <TextView
        android:id="@+id/accTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACCOUNT"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@+id/herobar"
        app:layout_constraintBottom_toBottomOf="@+id/herobar"
        app:layout_constraintStart_toEndOf="@+id/vertbar"
        android:layout_marginStart="30dp"
        android:layout_marginTop="50dp"/>


    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/cupw"
        app:layout_constraintBottom_toTopOf="@+id/achieveTxt"
        app:layout_constraintStart_toStartOf="@id/achieveTxt"
        app:layout_constraintEnd_toEndOf="@id/achieveTxt"
        />
    <TextView
        android:id="@+id/achieveTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACHIEVEMENTS"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@+id/herobar"
        app:layout_constraintBottom_toBottomOf="@+id/herobar"
        app:layout_constraintStart_toEndOf="@+id/accTxt"
        android:layout_marginStart="40dp"
        android:layout_marginTop="50dp"/>


    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:src="@drawable/dashw"
        app:layout_constraintBottom_toTopOf="@+id/dashb"
        app:layout_constraintEnd_toEndOf="@id/dashb"
        app:layout_constraintHorizontal_bias="0.375"
        app:layout_constraintStart_toStartOf="@id/dashb" />

    <TextView
        android:id="@+id/dashb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed-medium"
        android:text="Dash-Board"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.248"
        tools:layout_editor_absoluteX="4dp" />

    <ImageView
        android:id="@+id/reportsvg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/reportw"
        app:layout_constraintBottom_toTopOf="@+id/report"
        app:layout_constraintStart_toStartOf="@id/report"
        app:layout_constraintEnd_toEndOf="@id/report"
        />


    <TextView
        android:id="@+id/report"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed-medium"
        android:text="Weekly- Report"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/vertbar"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/vertbar"

        app:layout_constraintTop_toTopOf="@+id/vertbar"
        app:layout_constraintVertical_bias="0.398" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:src="@drawable/leaderw"
        app:layout_constraintBottom_toTopOf="@+id/leader"
        app:layout_constraintEnd_toEndOf="@id/leader"
        app:layout_constraintStart_toStartOf="@id/leader" />


    <TextView
        android:id="@+id/leader"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed-medium"
        android:text="Leader - Board"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.59"

        tools:layout_editor_absoluteX="0dp" />

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:src="@drawable/phoyow"
        app:layout_constraintBottom_toTopOf="@+id/compareph"
        app:layout_constraintEnd_toEndOf="@id/compareph"
        app:layout_constraintHorizontal_bias="0.45"
        app:layout_constraintStart_toStartOf="@id/compareph" />

    <TextView
        android:id="@+id/compareph"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed-medium"
        android:text="Before &amp; after photos"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.784"
        tools:layout_editor_absoluteX="4dp" />

    <FrameLayout
        android:id="@+id/cv1fit"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@color/black"
        android:elevation="10dp"
        app:layout_constraintTop_toBottomOf="@+id/herobar"
        app:layout_constraintStart_toEndOf="@+id/vertbar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <ImageView
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:scaleType="fitXY"
            android:src="@drawable/fitprofile"
            android:elevation="8dp"/>
    </FrameLayout>

    <TextView
        android:id="@+id/txtFitness"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:background="@color/gg"
        android:text="Fitness"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="30sp"
        app:layout_constraintTop_toBottomOf="@+id/cv1fit"
        app:layout_constraintStart_toStartOf="@+id/cv1fit"
        app:layout_constraintEnd_toEndOf="@+id/cv1fit"
        android:layout_marginTop="20dp"
         />

    <FrameLayout
        android:id="@+id/cv2diet"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@color/black"
        android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@+id/txtFitness"
        app:layout_constraintStart_toStartOf="@+id/cv1fit"
        android:layout_marginTop="40dp">

        <ImageView
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:scaleType="fitXY"
            android:src="@drawable/dietprof" />
    </FrameLayout>

    <TextView
        android:id="@+id/txtDiet"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="@color/gg"
        android:gravity="center"
        android:text="Diet"
        android:textColor="@color/white"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="@+id/cv2diet"
        app:layout_constraintHorizontal_bias="0.541"
        app:layout_constraintStart_toStartOf="@+id/cv2diet"
        app:layout_constraintTop_toBottomOf="@+id/cv2diet" />


    <ImageButton
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:backgroundTint="@color/navyy"
        android:src="@drawable/chatbott"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>